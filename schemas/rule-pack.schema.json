{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsecuritylens.dev/schemas/rule-pack.schema.json",
  "title": "AgentSecurityLens Rule Pack",
  "type": "object",
  "required": ["id", "version", "rules"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "severity",
          "confidence",
          "permissions",
          "target_paths",
          "patterns",
          "why_it_matters",
          "recommended_actions",
          "recommended_alternatives",
          "migration_instruction"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "execution-risk",
              "remote-access-risk",
              "data-exposure-risk",
              "supply-chain-risk",
              "persistence-automation-risk"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "match_scope": {
            "type": "string",
            "enum": ["line", "file"],
            "default": "line"
          },
          "supersedes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "why_it_matters": {
            "type": "string"
          },
          "recommended_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "migration_instruction": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
