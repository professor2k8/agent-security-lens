{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsecuritylens.dev/schemas/profile.schema.json",
  "title": "AgentSecurityLens Profile",
  "type": "object",
  "required": [
    "id",
    "version",
    "status",
    "confidence",
    "coverage",
    "rule_packs",
    "path_hints",
    "known_limitations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "experimental", "active", "deprecated", "archived"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "extends": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule_packs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "path_hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
